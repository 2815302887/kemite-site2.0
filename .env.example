# Node service port. In production, Nginx should proxy the public domain to this port.
PORT=3001

# Public HTTPS origin for the deployed site, for example https://www.example.com.
PUBLIC_ORIGIN=https://your-domain.example.com

# Comma-separated browser origins allowed to call the API.
# Production must set this explicitly.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,https://your-domain.example.com

# Local MySQL connection used by the website API and admin backend.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=solder_paste_site
DB_CONNECTION_LIMIT=10

# Replace this with a long random value before deployment.
JWT_SECRET=replace_with_a_strong_random_secret

# Local fallback admin account used when MySQL is not configured.
ADMIN_USERNAME=cl
ADMIN_PASSWORD=aacl520

# Upload and JSON body limits for product images and PDF datasheets.
JSON_LIMIT=12mb
UPLOAD_LIMIT_MB=8

# Number of automatic product-data backup files to keep.
BACKUP_RETENTION=50

# Contact form abuse protection. Defaults allow 5 submissions per IP per 15 minutes.
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
